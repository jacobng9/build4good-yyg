# NotesViz Backend Environment Variables
# Copy this file to .env and fill in your API key

# Google Gemini API Key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Image generation API (default: pollinations.ai — no key needed)
# Set to "stability" to use Stability AI instead
IMAGE_API=pollinations

# Stability AI API Key (optional, only if IMAGE_API=stability)
STABILITY_API_KEY=your_stability_api_key_here
